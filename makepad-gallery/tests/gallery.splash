use mod.test

test.configure({
    session_mode: "shared"
    action_timeout_ms: 5000
})

let router_nav = {
    go: fn(selector, expected_route) {
        test.click(selector)
        test.wait_text({id: "content_flip"}, expected_route)
    }
    go_deep: fn(selector, expected_route) {
        test.scroll({id: "sidebar"}, 0, 1800)
        test.click(selector)
        test.wait_text({id: "content_flip"}, expected_route)
    }
    expect_active_route: fn(expected_route) {
        test.wait_text({id: "content_flip"}, expected_route)
    }
    hover: fn(selector) {
        test.hover(selector)
    }
}

let nav = router_nav

test.case("gallery_default_accordion_page_renders", || {
    test.wait_text({id: "page_label"}, "Accordion")
    nav.expect_active_route("accordion_page")
    test.wait_visible({widget_type: "CodeView" text_contains: "ShadAccordion"})
})

test.case("gallery_sidebar_navigation_smoke", || {
    nav.go({id: "sidebar_button"}, "button_page")
    nav.go({id: "sidebar_accordion"}, "accordion_page")
})

test.case("gallery_theme_toggle_smoke", || {
    test.wait_visible({id: "theme_toggle"})
    test.click({id: "theme_toggle"})
    test.wait_visible({id: "theme_toggle" text_contains: "theme"})
    test.click({id: "theme_toggle"})
    test.wait_visible({id: "theme_toggle" text_contains: "theme"})
})

test.case("gallery_button_page_routes_and_renders_preview", || {
    nav.go({id: "sidebar_button"}, "button_page")
    test.wait_visible({widget_type: "CodeView" text_contains: "ShadButton"})
})

test.case("gallery_button_probe_tracks_hover_focus_press_and_click_state", || {
    nav.go({id: "sidebar_button"}, "button_page")
    test.hover({id: "button_probe_btn"})
    test.wait_text({id: "button_probe_state"}, "hovered=true down=false focused=false active=false enabled=true visible=true")
    test.click({id: "button_probe_btn"})
    test.wait_text({id: "button_probe_state"}, "hovered=true down=false focused=true active=false enabled=true visible=true")
    test.hover({id: "page_label"})
    test.wait_text({id: "button_probe_state"}, "hovered=false down=false focused=true active=false enabled=true visible=true")
})

test.case("gallery_badge_page_routes_and_renders_code", || {
    nav.go({id: "sidebar_badge"}, "badge_page")
    test.wait_visible({widget_type: "CodeView" text_contains: "ShadBadge"})
})

test.case("gallery_breadcrumb_page_routes_and_renders_code", || {
    nav.go({id: "sidebar_breadcrumb"}, "breadcrumb_page")
    test.wait_visible({widget_type: "CodeView" text_contains: "ShadBreadcrumb"})
})

test.case("gallery_button_group_page_routes_and_renders_code", || {
    nav.go({id: "sidebar_button_group"}, "button_group_page")
    test.wait_visible({widget_type: "CodeView" text_contains: "ShadButtonGroup"})
})

test.case("gallery_calendar_page_routes_and_renders_code", || {
    nav.go({id: "sidebar_calendar"}, "calendar_page")
    test.wait_visible({widget_type: "CodeView" text_contains: "ShadCalendar"})
})

test.case("gallery_calendar_hover_updates_status", || {
    nav.go({id: "sidebar_calendar"}, "calendar_page")
    test.hover({id: "calendar_demo"})
    test.wait_visible({id: "calendar_status" text_contains: "Hovered: 2026-"})
    test.hover({id: "page_label"})
    test.wait_visible({id: "calendar_status" text_contains: "Hovered: none."})
})

test.case("gallery_card_page_routes_and_renders_code", || {
    nav.go({id: "sidebar_card"}, "card_page")
    test.wait_visible({widget_type: "CodeView" text_contains: "ShadCard"})
})

test.case("gallery_checkbox_page_routes_and_renders_code", || {
    nav.go({id: "sidebar_checkbox"}, "checkbox_page")
    test.wait_visible({widget_type: "CodeView" text_contains: "ShadCheckbox"})
})

test.case("gallery_collapsible_page_routes_and_renders_code", || {
    nav.go({id: "sidebar_collapsible"}, "collapsible_page")
    test.wait_visible({widget_type: "CodeView" text_contains: "ShadCollapsible"})
})

test.case("gallery_sonner_page_routes_and_renders_code", || {
    nav.go_deep({id: "sidebar_sonner"}, "sonner_page")
    test.wait_visible({id: "toast_event_btn"})
    test.wait_visible({widget_type: "CodeView" text_contains: "ShadSonner"})
})

test.case("gallery_table_default_dataset_renders", || {
    nav.go_deep({id: "sidebar_table"}, "table_page")
    test.wait_visible({id: "table_demo"})
    test.scroll({id: "page_root"}, 0, 700)
    test.wait_text({id: "table_status"}, "Showing team roster. Selected row: none.")
    test.wait_visible({widget_type: "CodeView" text_contains: "ShadTable"})
})

test.case("gallery_table_switches_between_datasets", || {
    nav.go_deep({id: "sidebar_table"}, "table_page")
    test.scroll({id: "page_root"}, 0, 700)
    test.click({id: "table_ops_btn"})
    test.wait_text({id: "table_status"}, "Showing ops queue. Selected row: none.")
    test.click({id: "table_team_btn"})
    test.wait_text({id: "table_status"}, "Showing team roster. Selected row: none.")
})

test.case("gallery_table_virtual_window_pages_forward_and_back", || {
    nav.go_deep({id: "sidebar_table"}, "table_page")
    test.scroll({id: "page_root"}, 0, 700)
    test.click({id: "table_virtual_btn"})
    test.wait_text({id: "table_status"}, "Showing virtual jobs 0..31 of 10000. Selected row: none.")
    test.wait_visible({text_contains: "JOB-00000"})
    test.click({id: "table_next_btn"})
    test.wait_text({id: "table_status"}, "Showing virtual jobs 32..63 of 10000. Selected row: none.")
    test.wait_visible({text_contains: "JOB-00032"})
    test.click({id: "table_prev_btn"})
    test.wait_text({id: "table_status"}, "Showing virtual jobs 0..31 of 10000. Selected row: none.")
    test.wait_visible({text_contains: "JOB-00000"})
})
